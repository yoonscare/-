{
  "entities": {
    "User": {
      "title": "User",
      "description": "A teacher user",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "A counseling session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a session",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "createdAt": { "type": "number" }
      },
      "required": ["text", "role", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Stores counseling sessions for users"
    },
    "sessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages within a counseling session"
    }
  }
}
